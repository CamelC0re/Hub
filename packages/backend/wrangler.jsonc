{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "camelcore-api",
    "main": "src/index.ts",
    "compatibility_date": "2026-06-10",
    "d1_databases": [
        {
            "binding": "DB",
            "database_name": "camelcore-db",
            "database_id": "YOUR_ACTUAL_CLOUDFLARE_D1_DATABASE_UUID_HERE"
        }
    ],
    "r2_buckets": [
        {
            "binding": "STORAGE_BUCKET",
            "bucket_name": "camelcore-plugins"
        }
    ]
}