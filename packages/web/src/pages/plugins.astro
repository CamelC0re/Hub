---
import Layout from '../layouts/Layout.astro';
import PublicPluginList from '../components/PublicPluginList.svelte';
---

<Layout title="Approved Plugins - CamelCore">
	<main class="content-wrapper plugin-page-wrapper">
		<section class="panel plugin-panel">
			<h1>Approved Plugins</h1>
			<p>Explore the plugins approved for CamelCore.</p>

			<PublicPluginList client:load />
		</section>
	</main>
</Layout>

<style>
	.plugin-page-wrapper {
		align-items: flex-start; /* overrides center */
	}

	.plugin-panel {
		max-width: 1000px; /* Wider panel for the grid */
	}
</style>
